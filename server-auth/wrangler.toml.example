name = "coin-board-auth"
main = "cloudflare-worker.js"
compatibility_date = "2026-06-12"

[vars]
FRONTEND_ORIGIN = "https://fnfnfn3232.github.io"
NEWS_LIMIT = "40"
NEWS_STORE_LIMIT = "1000"
NEWS_BODY_MODE = "preview"
NEWS_CACHE_SECONDS = "600"

[[r2_buckets]]
binding = "BOARD_MEDIA_BUCKET"
bucket_name = "coin-board-media"

# Set these as secrets, not plain vars:
# wrangler secret put SITE_PASSWORD_SHA256
# wrangler secret put SESSION_SECRET
